# Supabase Local Development Credentials
# These will match the local Docker container outputs when running `supabase start`

# Public URL of the Supabase API Gateway
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Public Anon Key for client-side API requests and authentication
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Direct PostgreSQL database connection URL (used by Drizzle ORM)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
